// ----- KLÍČOVÉ VÝHODY (Services-style cards) -----
const featureCards = [
  { title: '4 bytové jednotky',                blurb: 'Plně rekonstruované byty od 1+KK do 4+1, vlastní kuchyně i koupelny.', image: { src: '/img/byt2/194A8487.webp', alt: '4 bytové jednotky' } },
  { title: 'Komerční prostory + zavedený salon', blurb: 'Kadeřnictví 100 m² s nájemcem, plus 2 menší provozovny v suterénu.', image: { src: '/img/salon/194A8704.webp', alt: 'Kadeřnický salon' } },
  { title: 'Fotovoltaika & úsporné vytápění',  blurb: 'Solární systém na střeše a garáži, nízké provozní náklady celoročně.', image: { src: '/img/fotovoltaika/194A8732.webp', alt: 'Fotovoltaika' } },
  { title: 'Venkovní výtah',                    blurb: 'Moderní skleněný výtah po celé výšce budovy — bezbariérový přístup.', image: { src: '/img/vytah/194A8718.webp', alt: 'Venkovní výtah' } },
  { title: 'Garáž pro 4 vozy + vířivka',        blurb: 'Krytá garáž 72 m², pergola, sudová vyhřívaná vířivka, oplocený pozemek.', image: { src: '/img/garaz/194A8701.webp', alt: 'Garáž' } },
  { title: 'Kamerový systém Hikvision',         blurb: 'Bezpečnostní systém po celém objektu — klid pro rezidenty i nájemce.', image: { src: '/img/exterior/194A8781.webp', alt: 'Kamerový systém' } },
];

// ----- BYTOVÉ JEDNOTKY -----
function toWebp(arr: string[]) {
  return arr.map(s => s.replace('/images/', '/img/').replace(/\.jpe?g$/, '.webp'));
}

const units = [
  {
    id: 1, name: 'Byt 1 — 1. patro', floor: '1. patro',
    area: '100 m²', layout: '3+1',
    description: 'Prostorný byt s vlastní kuchyní, koupelnou, vytápěním a elektroměrem. Moderní vybavení a kvalitní materiály.',
    gallery: toWebp(['/images/byt1/194A8437.jpg','/images/byt1/194A8439.jpg','/images/byt1/194A8442.jpg','/images/byt1/194A8444.jpg','/images/byt1/194A8447.jpg','/images/byt1/194A8454.jpg','/images/byt1/194A8457.jpg','/images/byt1/194A8459.jpg','/images/byt1/194A8462.jpg','/images/byt1/194A8469.jpg','/images/byt1/194A8471.jpg']),
  },
  {
    id: 2, name: 'Byt 2 — 2. patro', floor: '2. patro',
    area: '120 m²', layout: '3+1',
    description: 'Největší bytová jednotka s výborným dispozičním řešením. Vlastní kuchyň, koupelna, vytápění a elektroměr.',
    gallery: toWebp(['/images/byt2/194A8487.jpg','/images/byt2/194A8495.jpg','/images/byt2/194A8499.jpg','/images/byt2/194A8503.jpg','/images/byt2/194A8504.jpg','/images/byt2/194A8507.jpg','/images/byt2/194A8512.jpg','/images/byt2/194A8515.jpg','/images/byt2/194A8524.jpg','/images/byt2/194A8527.jpg','/images/byt2/194A8528.jpg','/images/byt2/194A8530.jpg','/images/byt2/194A8532.jpg','/images/byt2/194A8533.jpg','/images/byt2/194A8535.jpg','/images/byt2/194A8540.jpg']),
  },
  {
    id: 3, name: 'Byt 3 — 3. patro', floor: '3. patro',
    area: '120 m²', layout: '4+1',
    description: 'Nejvíce pokojů ze všech bytů. Prostorná jednotka s výhledem na historické centrum. Vlastní kuchyň, koupelna, vytápění a elektroměr.',
    gallery: toWebp(['/images/byt3/194A8587.jpg','/images/byt3/194A8588.jpg','/images/byt3/194A8590.jpg','/images/byt3/194A8593.jpg','/images/byt3/194A8596.jpg','/images/byt3/194A8602.jpg','/images/byt3/194A8604.jpg','/images/byt3/194A8605.jpg','/images/byt3/194A8607.jpg','/images/byt3/194A8609.jpg','/images/byt3/194A8610.jpg','/images/byt3/194A8615.jpg','/images/byt3/194A8616.jpg','/images/byt3/194A8620.jpg','/images/byt3/194A8625.jpg','/images/byt3/194A8629.jpg']),
  },
  {
    id: 4, name: 'Byt 4 — Podkroví', floor: 'Podkroví',
    area: '90 m²', layout: '1+KK',
    description: 'Jedinečný podkrovní byt s designovým stropem s motivem oblohy. Šikmé střešní okna poskytují přirozené světlo a nezapomenutelný výhled.',
    gallery: toWebp(['/images/byt4/194A8558.jpg','/images/byt4/194A8560.jpg','/images/byt4/194A8562.jpg','/images/byt4/194A8565.jpg','/images/byt4/194A8570.jpg','/images/byt4/194A8574.jpg']),
  },
];

// ----- TECHNOLOGIE (fotovoltaika, výtah, vířivka, salon, kamery) -----
const technologyImages = [
  { url: '/img/fotovoltaika/194A8732.webp', alt: 'Fotovoltaické panely',             caption: 'Solární systém s výhledem na Vejprty' },
  { url: '/img/fotovoltaika/194A8749.webp', alt: 'Solární panely — detail',          caption: 'Fotovoltaická instalace na budově' },
  { url: '/img/fotovoltaika/194A8690.webp', alt: 'Střídač a rozvaděč',               caption: 'Technologie pro správu solární energie' },
  { url: '/img/garaz/194A8701.webp',        alt: 'Garáž s fotovoltaikou',            caption: 'Garáž pro 4 vozy s panely na střeše' },
  { url: '/img/garaz/194A8699.webp',        alt: 'Garáž — interiér',                 caption: 'Prostorná garáž s parkovacími místy' },
  { url: '/img/exterior/194A8760.webp',     alt: 'Venkovní výtah',                   caption: 'Moderní exteriérový výtah na budově' },
  { url: '/img/vytah/194A8718.webp',        alt: 'Výtah — interiér',                 caption: 'Skleněný výtah s ovládacím panelem' },
  { url: '/img/vytah/194A8497.webp',        alt: 'Pohled z výtahu',                  caption: 'Výhled z výtahu do obytných prostor' },
  { url: '/img/exterior/194A8758.webp',     alt: 'Zahrada a venkovní posezení',      caption: 'Zahrada s pergolou a relaxačními prostory' },
  { url: '/img/exterior/194A8746.webp',     alt: 'Vířivka v zahradě',                caption: 'Venkovní vířivá vana s horským výhledem' },
  { url: '/img/salon/194A8704.webp',        alt: 'Kadeřnický salon',                 caption: 'Profesionální kadeřnictví — zavedený provoz' },
  { url: '/img/exterior/194A8781.webp',     alt: 'Kamerový systém',                  caption: 'Bezpečnostní systém Hikvision' },
];

// ----- SPOLEČNÉ PROSTORY -----
const commonAreas = [
  { url: '/img/chodby/194A8531.webp', alt: 'Historické schodiště',  caption: 'Původní dřevěné schodiště se zachovanými detaily' },
  { url: '/img/chodby/194A8646.webp', alt: 'Vstupní prostor',       caption: 'Vstup do budovy s moderní podlahou' },
  { url: '/img/chodby/194A8647.webp', alt: 'Chodba — 1. patro',     caption: 'Čistá, světlá chodba s moderním osvětlením' },
  { url: '/img/chodby/194A8648.webp', alt: 'Chodba — detail',       caption: 'Prostorné společné prostory' },
  { url: '/img/chodby/194A8660.webp', alt: 'Schodiště shora',       caption: 'Vertikální propojení všech pater' },
  { url: '/img/chodby/194A8661.webp', alt: 'Společné prostory',     caption: 'Udržované chodby a přístupové cesty' },
];

// ----- SKLEP -----
const storageBasement = [
  { url: '/img/sklep/194A8665.webp', alt: 'Sklep — technická místnost',  caption: 'Kotelna s moderním vytápěcím systémem' },
  { url: '/img/sklep/194A8669.webp', alt: 'Sklep — úložný prostor',      caption: 'Sklepní prostory s regály' },
  { url: '/img/sklep/194A8671.webp', alt: 'Sklep — chodba',              caption: 'Přístupové prostory v suterénu' },
  { url: '/img/sklep/194A8672.webp', alt: 'Sklep — skladovací místnost', caption: 'Suché skladovací prostory' },
  { url: '/img/sklep/194A8674.webp', alt: 'Sklep — další místnost',      caption: 'Dodatečné úložné prostory' },
  { url: '/img/sklep/194A8675.webp', alt: 'Sklep — technické zázemí',    caption: 'Rozvodny a technická infrastruktura' },
];

// ----- WELLNESS -----
const wellnessImages = [
  { url: '/img/wellness/194A8687.webp', alt: 'Wellness místnost s vířivkou', caption: 'Privátní relaxační prostor s vířivou vanou' },
  { url: '/img/wellness/194A8688.webp', alt: 'Vířivka — detail',             caption: 'Speciální místnost s geometrickým stropem a loveckými trofejemi' },
  { url: '/img/wellness/194A8689.webp', alt: 'Wellness — interiér',          caption: 'Unikátní prostor pro odpočinek a relaxaci' },
];

// ----- LOKALITA accordion -----
const locGroups = [
  {
    id: 'okoli',
    title: 'Lokalita & příroda',
    content: `<p>Vejprty leží v srdci <strong>Krušných hor</strong> — oblasti, která spojuje klid,
      přírodu a výjimečné možnosti pro volný čas.</p>
      <ul>
        <li><strong>5 minut</strong> od hranic s Německem.</li>
        <li><strong>15 minut</strong> od Klínovce.</li>
        <li>Dům se nachází přímo na náměstí.</li>
      </ul>`,
  },
  {
    id: 'klinovec',
    title: 'Sport — Skiareál Klínovec',
    content: `<p>Klínovec je <strong>největší lyžařsky propojené středisko v Česku</strong>.</p>
      <ul>
        <li>30 km sjezdovek</li>
        <li>5 moderních lanovek</li>
        <li>Propojení s německým Fichtelbergem — celkem více než 44 km tratí</li>
      </ul>`,
  },
  {
    id: 'bikepark',
    title: 'Léto — Bikepark Klínovec',
    content: `<p>V létě se Klínovec proměňuje v jeden z <strong>největších bikeparků v Evropě</strong>,
      součást sítě Gravity.</p>
      <p>Čekají tu jedny z nejdelších flow trailů na kontinentu, včetně tras zařazených
      mezi <strong>10 nejlepších na světě</strong>.</p>`,
  },
  {
    id: 'investice',
    title: 'Lokalita jako investice',
    content: `<p>Turistická oblast s vysokou poptávkou po ubytování po celý rok.</p>
      <ul>
        <li>Strategická poloha blízko Německa přitahuje nájemce.</li>
        <li>Vhodné pro bydlení, rekreaci i dlouhodobý pronájem.</li>
        <li>Lokalita, která žije po celý rok.</li>
      </ul>`,
  },
];

// ----- INVBUILD GATEWAY -----
const gatewayCards = [
  {
    title: 'Naše projekty',
    blurb: 'Další developerské projekty od INVBUILD — nízkoenergetické stavby i rekonstrukce.',
    image: { src: '/img/dron_2.webp', alt: 'Developerské projekty INVBUILD' },
    href: 'https://invbuild.cz/projekty',
    external: true,
  },
  {
    title: 'Reality v nabídce',
    blurb: 'Prodej i pronájem nemovitostí s profesionálním a lidským přístupem.',
    image: { src: '/img/exterior/194A8787.webp', alt: 'Reality INVBUILD' },
    href: 'https://invbuild.cz/reality',
    external: true,
  },
  {
    title: 'Naše služby',
    blurb: 'Hypotéka, odhad, pojištění, právní servis, foto/video, VR prohlídky.',
    image: { src: '/img/wellness/194A8687.webp', alt: 'Služby INVBUILD' },
    href: 'https://invbuild.cz',
    external: true,
  },
];

const navItems = [
  { id: 'hero',         label: 'Úvod' },
  { id: 'vyhody',       label: 'Výhody' },
  { id: 'vejprty',      label: 'O projektu' },
  { id: 'byty',         label: 'Byty' },
  { id: 'komerce',      label: 'Komerce' },
  { id: 'technologie',  label: 'Technologie' },
  { id: 'prostory',     label: 'Prostory' },
  { id: 'wellness',     label: 'Wellness' },
  { id: 'investice',    label: 'Investice' },
  { id: 'lokalita',     label: 'Lokalita' },
  { id: 'galerie',      label: 'Galerie' },
  { id: 'invbuild',     label: 'INVBUILD' },
  { id: 'kontakt',      label: 'Kontakt' },
];
---

<Layout>
  <Header />
  <SectionNav items={navItems} />

  <Hero
    title="Vejprty — dům, který vydělává a žije"
    location="Vejprty · Krušné hory"
    stats={stats}
    images={heroImages}
  />

  <!-- 01 — KLÍČOVÉ VÝHODY -->
  <Section
    id="vyhody"
    variant="dark"
    num="01"
    eyebrow="Klíčové výhody"
    title="Bydlení, podnikání a investice v jednom."
    intro="Čtyři bytové jednotky, komerční prostory a moderní technologie v srdci Krušných hor."
  >
    <Services items={featureCards} />
  </Section>

  <!-- 02 — O PROJEKTU -->
  <Section id="vejprty" variant="bone">
    <StorySplit
      num="02"
      eyebrow="O projektu"
      title="Dům, který má duši"
      caption="Drone fotografie — Vejprty"
      image={{ src: '/img/dron_1.webp', alt: 'Vejprty — letecký pohled na nemovitost' }}
    >
      <p>
        Výjimečný rodinný dům ve Vejprtech spojuje <strong>historii</strong>, moderní
        technologie a investiční potenciál. Nachází se přímo na náměstí a nabízí široké
        možnosti využití — od vícegeneračního bydlení po komerční účely.
      </p>
      <p>
        Dům prošel <strong>kompletní rekonstrukcí</strong> zahrnující novou fasádu, střechu
        a kanalizaci a je připraven k okamžitému užívání.
      </p>
      <p>
        Součástí objektu je i udržovaná zahrada s pergolou, vytápěná <strong>sudová
        vířivka</strong>, garáž 72 m² pro čtyři vozidla a chlívky pro drobná zvířata.
        Celý pozemek je oplocen a nabízí soukromí pro rezidenty i návštěvníky.
      </p>
      <p class="split__cta-wrap">
        <a href="#kontakt" class="btn btn--accent">Domluvit prohlídku</a>
      </p>
    </StorySplit>

    <!-- Klíčové parametry -->
    <div class="params" data-reveal>
      <div class="params__item"><span class="params__val lining">629 m²</span><span class="params__lbl">Zastavěná plocha</span></div>
      <div class="params__item"><span class="params__val lining">72 m²</span><span class="params__lbl">Garáž (4 vozy)</span></div>
      <div class="params__item"><span class="params__val lining">652 m²</span><span class="params__lbl">Ostatní plocha</span></div>
      <div class="params__item"><span class="params__val lining">430 m²</span><span class="params__lbl">Celková plocha bytů</span></div>
    </div>
  </Section>

  <!-- 03 — BYTOVÉ JEDNOTKY -->
  <Section
    id="byty"
    variant="dark"
    num="03"
    eyebrow="Dispozice"
    title="Čtyři samostatné bytové jednotky"
    intro="Každý byt má vlastní kuchyň, koupelnu, vytápění a elektroměr. Klikněte na jednotku pro detail a galerii."
    width="wide"
  >
    <Units units={units} />
  </Section>

  <!-- 04 — KOMERCE -->
  <Section id="komerce" variant="bone">
    <StorySplit
      num="04"
      eyebrow="Komerční prostory"
      title="Kadeřnický salon — zavedený provoz"
      caption="Salon — 100 m²"
      image={{ src: '/img/salon/194A8703.webp', alt: 'Kadeřnický salon' }}
    >
      <p>
        Plně zařízené <strong>kadeřnictví o ploše 100 m²</strong> s moderním vybavením
        a stálou klientelou. Současná nájemnice si přeje zůstat — okamžitý pasivní příjem
        pro nového majitele.
      </p>
      <p>
        Součástí objektu jsou i <strong>dvě malé provozovny v suterénu</strong>
        (kadeřnictví a vinárna) a další nebytové prostory.
      </p>
    </StorySplit>
  </Section>

  <!-- 05 — TECHNOLOGIE -->
  <Section
    id="technologie"
    variant="dark"
    num="05"
    eyebrow="Technologie & vybavení"
    title="Moderní systémy pro úsporný provoz"
    intro="Nemovitost je plně zrekonstruována — fotovoltaika, venkovní výtah, vířivka, kamerový systém."
    width="wide"
  >
    <ImageGrid images={technologyImages} aspect="4 / 3" />
  </Section>

  <!-- 06 — SPOLEČNÉ PROSTORY -->
  <Section
    id="prostory"
    variant="bone"
    num="06"
    eyebrow="Společné prostory"
    title="Historické schodiště, moderní chodby"
    intro="Společné prostory zachovávají historické detaily a doplňují je moderní úpravy."
    width="wide"
  >
    <ImageGrid images={commonAreas} aspect="4 / 3" />

    <div class="prostory__divider" aria-hidden="true"></div>

    <header class="sub-head" data-reveal>
      <span class="eyebrow"><span class="eyebrow__num">06.B</span><span>Sklep & další prostory</span></span>
      <h3>Technické zázemí a multifunkční místnost</h3>
    </header>
    <ImageGrid images={storageBasement} aspect="4 / 3" />
  </Section>

  <!-- 07 — WELLNESS -->
  <Section
    id="wellness"
    variant="dark"
    num="07"
    eyebrow="Relax & wellness"
    title="Privátní wellness s vířivkou"
    intro="Speciální místnost s unikátním geometrickým stropem a loveckými trofejemi — prostor pro odpočinek."
  >
    <ImageGrid images={wellnessImages} aspect="4 / 3" minWidth="280px" />
  </Section>

  <!-- 08 — INVESTIČNÍ POTENCIÁL -->
  <Section
    id="investice"
    variant="bone"
    num="08"
    eyebrow="Investiční potenciál"
    title="Atraktivní dlouhodobá investice"
    align="center"
    width="default"
  >
    <div class="invest" data-reveal>
      <div class="invest__cards">
        <div class="invest__card">
          <span class="invest__val lining">4</span>
          <span class="invest__lbl">Pronajatelné byty</span>
        </div>
        <div class="invest__card">
          <span class="invest__val">Zavedený</span>
          <span class="invest__lbl">Komerční prostor</span>
        </div>
        <div class="invest__card">
          <span class="invest__val">FV</span>
          <span class="invest__lbl">Úsporný provoz</span>
        </div>
      </div>

      <ul class="invest__points">
        <li><strong>Diversifikace příjmů</strong> z rezidenčních i komerčních prostor</li>
        <li><strong>Strategická poloha</strong> blízko Německa přitahuje nájemce</li>
        <li><strong>Nízké provozní náklady</strong> díky fotovoltaice a úspornému vytápění</li>
        <li><strong>Turistická oblast</strong> s vysokou poptávkou po ubytování celoročně</li>
      </ul>

      <p class="invest__close">
        Tato nemovitost představuje ideální kombinaci <strong>bydlení a podnikání</strong>
        v jednom. Díky moderním technologiím, nízkým provozním nákladům a atraktivní
        poloze v srdci Krušných hor jde o stabilní a dlouhodobě výnosnou investici.
      </p>
    </div>
  </Section>

  <!-- 09 — LOKALITA -->
  <Section
    id="lokalita"
    variant="dark"
