---
import Layout      from '../layouts/Layout.astro';
import Header      from '../components/Header.astro';
import Hero        from '../components/Hero.astro';
import Section     from '../components/Section.astro';
import SectionNav  from '../components/SectionNav.astro';
import Gallery     from '../components/Gallery.astro';
import StorySplit  from '../components/StorySplit.astro';
import Lokalita    from '../components/Lokalita.astro';
import Services    from '../components/Services.astro';
import Units       from '../components/Units.astro';
import ImageGrid   from '../components/ImageGrid.astro';
import Kontakt     from '../components/Kontakt.astro';
import Footer      from '../components/Footer.astro';
import Reveal      from '../components/Reveal.astro';

// ----- HERO -----
const stats = [
  { label: 'Cena',                 value: '19 334 000 Kč' },
  { label: 'Bytové jednotky',      value: '4'             },
  { label: 'Celková plocha bytů',  value: '430 m²'        },
  { label: 'Komerční prostor',     value: '100 m²'        },
];

const heroImages = [
  { src: '/img/dron_1.webp', alt: 'Vejprty — letecký pohled na nemovitost' },
  { src: '/img/dron_3.webp', alt: 'Vejprty — pohled na dům a okolní krajinu' },
  { src: '/img/dron_5.webp', alt: 'Vejprty — panoramatický pohled' },
];

// ----- GALERIE (drone shots) -----
const galleryImages = [
  { src: '/img/dron_1.webp', alt: 'Letecký pohled — celkový' },
  { src: '/img/dron_2.webp', alt: 'Drone fotografie z výšky' },
  { src: '/img/dron_3.webp', alt: 'Dům a okolní krajina Krušných hor' },
  { src: '/img/dron_4.webp', alt: 'Vejprty z ptačí perspektivy' },
  { src: '/img/dron_5.webp', alt: 'Panoramatický pohled na lokalitu' },
  { src: '/img/exterior/194A8787.webp', alt: 'Historické centrum Vejprt' },
  { src: '/img/exterior/194A8790.webp', alt: 'Vejprty — náměstí' },
  { src: '/img/exterior/194A8726.webp', alt: 'Zahrada s pergolou' },
  { src: '/img/exterior/194A8738.webp', alt: 'Zahradní altán' },
  { src: '/img/exterior/194A8730.webp', alt: 'Venkovní výtah — detail' },
